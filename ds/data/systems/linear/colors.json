{
  "modes": ["dark", "light", "glass"],
  "overview": [
    {
      "label": "Palette",
      "value": "No ramps \u2014 a dozen named primitives in :root plus per-theme semantic tokens",
      "note": "Scope: linear.app's marketing-site CSS; the product app is behind authentication. Translucency is per-token 8-digit hex, not alpha ramps.",
      "sources": [
        "https://static.linear.app/web/_next/static/index-pNKhUyF9.css"
      ]
    },
    {
      "label": "Generation",
      "value": "LCH-space theme generator \u2014 three inputs: base color, accent color, contrast (closed)",
      "note": "First-party: 'instead of having to define 98 specific variables for each theme, we defined three'. Shipped CSS carries only the pre-resolved output.",
      "sources": [
        "https://linear.app/now/how-we-redesigned-the-linear-ui",
        "https://linear.app/changelog/2020-12-04-themes"
      ]
    },
    {
      "label": "Color space",
      "value": "LCH working space; ships pre-resolved sRGB hex plus runtime color-mix(in lch, ...)",
      "note": "Wide gamut is a single upgraded primitive (--color-blue in display-p3 under @supports) \u2014 an afterthought, not a strategy.",
      "sources": [
        "https://static.linear.app/web/_next/static/index-pNKhUyF9.css",
        "https://linear.app/now/how-we-redesigned-the-linear-ui"
      ]
    },
    {
      "label": "Contrast",
      "value": "Contrast is a generator input powering auto-generated high-contrast themes; standard and targets unpublished",
      "note": "Mechanism documented, guarantees unknown \u2014 nothing recoverable from shipped CSS.",
      "sources": ["https://linear.app/now/how-we-redesigned-the-linear-ui"]
    },
    {
      "label": "Theming",
      "value": "CSS custom properties re-pointed per data-theme on <html> \u2014 dark, light, glass",
      "note": null,
      "sources": [
        "https://static.linear.app/web/_next/static/index-pNKhUyF9.css"
      ]
    },
    {
      "label": "Naming",
      "value": "kebab-case --color-{concept}-{variant}; two semantic generations coexist",
      "note": "An ordinal set (bg-primary\u2026quinary, text-primary\u2026quaternary) ships alongside a newer surface set (bg-level-0..3, fg-*, line-*) \u2014 rank vs elevation, a token refactor visible live.",
      "sources": [
        "https://static.linear.app/web/_next/static/index-pNKhUyF9.css"
      ]
    }
  ],
  "layers": [
    {
      "name": "named primitives (:root)",
      "kind": "primitive",
      "example": "--color-blue: #4ea7fc",
      "note": "A dozen single-value colors \u2014 no ramps ship at all."
    },
    {
      "name": "ordinal semantic set",
      "kind": "semantic",
      "example": "--color-bg-primary \u2026 --color-bg-quinary",
      "note": "The older generation: rank-based naming."
    },
    {
      "name": "surface semantic set",
      "kind": "semantic",
      "example": "--color-bg-level-0..3, --color-fg-*, --color-line-*",
      "note": "The newer generation: elevation-based naming, covering the same ground."
    }
  ],
