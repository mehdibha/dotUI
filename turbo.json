{
	"$schema": "https://turborepo.org/schema.json",
	"tasks": {
		"build": {
			"dependsOn": ["^build"],
			"outputs": [".output/**", ".vercel/**", "dist/**"]
		},
		"dev": {
			"cache": false
		},
		"//#check": {},
		"//#check:fix": {
			"cache": false
		},
		"//#check:ci": {},
		"typecheck": {
			"dependsOn": ["^build"]
		},
		"test": {
			"cache": false,
			"outputs": []
		},
		"clean": {
			"cache": false
		},
		"//#clean": {
			"cache": false
		},
		"push": {
			"cache": false,
			"interactive": true
		},
		"studio": {
			"cache": false,
			"persistent": true
		}
	},
	"globalEnv": ["PORT"],
	"globalPassThroughEnv": ["NODE_ENV", "CI", "VERCEL", "VERCEL_ENV", "VERCEL_URL", "npm_lifecycle_event", "PORTLESS", "PORTLESS_PORT"]
}
