    "variant": {
      "type": "\"floating\" | \"inset\" | \"sidebar\"",
      "detailedType": "'floating' | 'inset' | 'sidebar' | undefined",
      "typeAst": {
        "type": "union",
        "elements": [
          {
            "type": "stringLiteral",
            "value": "floating"
          },
          {
            "type": "stringLiteral",
