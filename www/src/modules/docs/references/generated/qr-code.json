{
  "name": "QRCodeProps",
  "description": "A QR code encodes a value, such as a URL, as a scannable matrix barcode.",
  "extendsElement": "div",
  "props": {
    "value": {
      "type": "string",
      "typeAst": {
        "type": "string"
      },
      "description": "The value to encode, such as a URL or plain text.",
      "required": true
    },
    "errorCorrection": {
      "type": "\"H\" | \"L\" | \"M\" | \"Q\"",
      "detailedType": "'H' | 'L' | 'M' | 'Q' | undefined",
      "typeAst": {
        "type": "union",
        "elements": [
          {
            "type": "stringLiteral",
            "value": "H"
          },
          {
            "type": "stringLiteral",
            "value": "L"
          },
          {
            "type": "stringLiteral",
            "value": "M"
          },
          {
            "type": "stringLiteral",
            "value": "Q"
          }
        ]
      },
      "description": "The error correction level. Higher levels tolerate more visual damage\n(L 7%, M 15%, Q 25%, H 30%) at the cost of a denser code.",
      "default": "'M' — 'H' when a logo is present"
    },
    "children": {
      "type": "ReactNode",
      "typeAst": {
        "type": "identifier",
        "name": "ReactNode"
      },
      "description": "An optional logo displayed at the center of the code. Modules behind it\nare excavated, and the default error correction level is raised to 'H'."
    },
    "className": {
      "type": "string",
      "typeAst": {
        "type": "string"
      },
      "description": "The CSS [className](https://developer.mozilla.org/en-US/docs/Web/API/Element/className) for the element."
    }
  }
}
