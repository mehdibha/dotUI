{
  "name": "FieldProps",
  "description": "A field wraps a form control with its label, description, and error message.",
  "extendsElement": "div",
  "props": {
    "orientation": {
      "type": "\"horizontal\" | \"vertical\"",
      "detailedType": "'horizontal' | 'vertical' | undefined",
      "typeAst": {
        "type": "union",
        "elements": [
          {
            "type": "stringLiteral",
            "value": "horizontal"
          },
          {
            "type": "stringLiteral",
            "value": "vertical"
          }
        ]
      },
      "description": "The orientation of the field layout.",
      "default": "'vertical'"
    },
    "className": {
      "type": "string",
      "typeAst": {
        "type": "string"
      },
      "description": "The CSS [className](https://developer.mozilla.org/en-US/docs/Web/API/Element/className) for the element."
    }
  }
}
