{
  "name": "DrawerProps",
  "description": "A React Aria compatible drawer overlay powered by Base UI's Drawer overlay\nprimitives.",
  "props": {
    "placement": {
      "type": "DrawerPlacement",
      "detailedType": "DrawerPlacement | undefined",
      "typeAst": {
        "type": "identifier",
        "name": "DrawerPlacement"
      },
      "description": "The side of the screen where the drawer appears.",
      "default": "'bottom'"
    },
    "isOpen": {
      "type": "boolean",
      "detailedType": "boolean | undefined",
      "typeAst": {
        "type": "boolean"
      },
      "description": "Whether the drawer is open."
    },
    "defaultOpen": {
      "type": "boolean",
      "detailedType": "boolean | undefined",
      "typeAst": {
        "type": "boolean"
      },
      "description": "Whether the drawer is open by default.",
      "default": "false"
    },
    "onOpenChange": {
      "type": "((open: boolean) => void)",
      "detailedType": "((open: boolean) => void) | undefined",
      "typeAst": {
        "type": "function",
        "parameters": [
          {
            "type": "parameter",
            "name": "open",
            "value": {
              "type": "link",
              "id": "boolean",
              "name": "boolean"
            },
            "optional": false,
            "rest": false
          }
        ],
        "return": {
          "type": "void"
        },
        "typeParameters": []
      },
      "description": "Handler that is called when the drawer's open state changes."
    },
    "swipeToDismiss": {
      "type": "boolean",
      "detailedType": "boolean | undefined",
      "typeAst": {
        "type": "boolean"
      },
      "description": "Whether the user can drag the drawer to dismiss it.",
      "default": "true"
    },
    "isDismissable": {
      "type": "boolean",
      "detailedType": "boolean | undefined",
      "typeAst": {
        "type": "boolean"
      },
      "description": "Whether outside interaction closes the drawer.",
      "default": "true"
    },
    "isKeyboardDismissDisabled": {
      "type": "boolean",
      "detailedType": "boolean | undefined",
      "typeAst": {
        "type": "boolean"
      },
      "description": "Whether pressing Escape is suppressed.",
      "default": "false"
    },
    "className": {
      "type": "string",
      "typeAst": {
        "type": "string"
      },
      "description": "The CSS [className](https://developer.mozilla.org/en-US/docs/Web/API/Element/className) for the element."
    },
    "children": {
      "type": "ReactNode",
      "typeAst": {
        "type": "identifier",
        "name": "ReactNode"
      },
      "description": "The content of the drawer."
    }
  },
  "renderProps": {
    "open": {
      "selector": "[data-open]",
      "tailwind": "data-open:",
      "description": "Present when the drawer is open."
    },
    "closed": {
      "selector": "[data-closed]",
      "tailwind": "data-closed:",
      "description": "Present when the drawer is closed."
    },
    "startingStyle": {
      "selector": "[data-starting-style]",
      "tailwind": "data-starting-style:",
      "description": "Present when the drawer is animating in."
    },
    "endingStyle": {
      "selector": "[data-ending-style]",
      "tailwind": "data-ending-style:",
      "description": "Present when the drawer is animating out."
    },
    "expanded": {
      "selector": "[data-expanded]",
      "tailwind": "data-expanded:",
      "description": "Present when the drawer is at the expanded (full-height) snap point."
    },
    "nestedDrawerOpen": {
      "selector": "[data-nested-drawer-open]",
      "tailwind": "data-nested-drawer-open:",
      "description": "Present when a nested drawer is open."
    },
    "nestedDrawerSwiping": {
      "selector": "[data-nested-drawer-swiping]",
      "tailwind": "data-nested-drawer-swiping:",
      "description": "Present when a nested drawer is being swiped."
    },
    "swipeDismiss": {
      "selector": "[data-swipe-dismiss]",
      "tailwind": "data-swipe-dismiss:",
      "description": "Present when the drawer is dismissed by swiping."
    },
    "swipeDirection": {
      "selector": "[data-swipe-direction]",
      "tailwind": "data-swipe-direction:",
      "description": "Indicates the swipe direction."
    },
    "swiping": {
      "selector": "[data-swiping]",
      "tailwind": "data-swiping:",
      "description": "Present when the drawer is being swiped."
    }
  },
  "renderPropsKind": "data-attribute"
}
